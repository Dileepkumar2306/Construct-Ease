{
  "name": "construct-ease-root",
  "version": "1.0.0",
  "description": "Root runner for Construct Ease project",
  "scripts": {
    "postinstall": "npm install --prefix client && npm install --prefix server",
    "build": "npm run build --prefix client",
    "dev": "concurrently \"npm start --prefix server\" \"npm start --prefix client\"",
    "desktop": "npm run desktop --prefix client",
    "cap:sync": "npm run cap:sync --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.4.1",
    "nodemailer": "^6.9.13",
    "twilio": "^5.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
