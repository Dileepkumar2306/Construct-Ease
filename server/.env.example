# ────────────────────────────────────────────────────────────────────
# Construct Ease — Server Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────

# MongoDB
MONGO_URI=mongodb://localhost:27017/construct_ease_db

# Server
PORT=5000

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# ── Email OTP (Gmail SMTP) ───────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account.
# 2. Go to myaccount.google.com → Security → App passwords.
# 3. Generate a 16-character app password and paste it below.
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ── SMS OTP (Twilio) ─────────────────────────────────────────────────
# Sign up at twilio.com, get a trial phone number, then copy your
# Account SID and Auth Token from the Twilio Console.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
